    if (s.pharmAddress && s.pharmAddress.includes('الرياض')) delete s.pharmAddress;
    if (s.currency === 'ر.س') delete s.currency;
    if (s.pharmPhone === '0500000000') delete s.pharmPhone;
    if (s.taxRate === 15) s.taxRate = 0;
    settings = { ...settings, ...s };
    return;
  }
  products = [
    { id: 1, name: 'باراسيتامول 500mg', scientific: 'Paracetamol', barcode: '6291001234561', category: 'مسكنات الألم', price: 5.50, cost: 2.50, stock: 150, unit: 'علبة', expiry: '2026-08', manufacturer: 'المختبرات السعودية', icon: '💊' },
    { id: 2, name: 'أموكسيسيللين 500mg', scientific: 'Amoxicillin', barcode: '6291001234562', category: 'مضادات حيوية', price: 28.00, cost: 15.00, stock: 60, unit: 'علبة', expiry: '2025-12', manufacturer: 'فايزر', icon: '🔵' },
    { id: 3, name: 'فيتامين C 1000mg', scientific: 'Ascorbic Acid', barcode: '6291001234563', category: 'فيتامينات', price: 35.00, cost: 18.00, stock: 8, unit: 'علبة', expiry: '2026-03', manufacturer: 'هولستا', icon: '🟡' },
    { id: 4, name: 'ميترونيدازول 250mg', scientific: 'Metronidazole', barcode: '6291001234564', category: 'مضادات حيوية', price: 12.00, cost: 5.00, stock: 45, unit: 'علبة', expiry: '2026-11', manufacturer: 'المختبرات السعودية', icon: '💊' },
    { id: 5, name: 'أوميبرازول 20mg', scientific: 'Omeprazole', barcode: '6291001234565', category: 'جهاز هضمي', price: 22.00, cost: 10.00, stock: 0, unit: 'علبة', expiry: '2026-06', manufacturer: 'أسترازينيكا', icon: '🔴' },
    { id: 6, name: 'لوراتادين 10mg', scientific: 'Loratadine', barcode: '6291001234566', category: 'جهاز تنفسي', price: 18.50, cost: 8.00, stock: 72, unit: 'علبة', expiry: '2027-01', manufacturer: 'شيرينغ', icon: '💊' },
    { id: 7, name: 'فيتامين D3 1000IU', scientific: 'Cholecalciferol', barcode: '6291001234567', category: 'فيتامينات', price: 45.00, cost: 25.00, stock: 30, unit: 'زجاجة', expiry: '2026-09', manufacturer: 'بيوفيتال', icon: '🌟' },
    { id: 8, name: 'ميتفورمين 500mg', scientific: 'Metformin', barcode: '6291001234568', category: 'سكري وضغط', price: 16.00, cost: 7.00, stock: 90, unit: 'علبة', expiry: '2026-12', manufacturer: 'سانوفي', icon: '💊' },
    { id: 9, name: 'كلوريد الصوديوم 0.9%', scientific: 'Sodium Chloride', barcode: '6291001234569', category: 'مستلزمات طبية', price: 8.00, cost: 3.00, stock: 5, unit: 'زجاجة', expiry: '2025-11', manufacturer: 'بكستر', icon: '💉' },
    { id: 10, name: 'كريم هيدروكورتيزون', scientific: 'Hydrocortisone', barcode: '6291001234570', category: 'جلدية', price: 24.00, cost: 12.00, stock: 25, unit: 'أنبوب', expiry: '2027-02', manufacturer: 'جي إس كي', icon: '🧴' },
