<script>
// ============================================================
// STATE
// ============================================================
let products = [];
let cart = [];
let sales = [];
let settings = {
  pharmName: 'صيدلية النسور',
  pharmLicense: 'PH-2024-001',
  pharmAddress: 'الفلوجة، محافظة الأنبار، العراق',
  pharmPhone: '07800000000',
  currency: 'د.ع',
  taxRate: 0,
  lowStockThreshold: 10,
  expiryWarnDays: 30
};
let currentPaymentMethod = 'cash';
let editingProductId = null;

// ============================================================
// SAMPLE DATA
// ============================================================
function initData() {
  const saved = localStorage.getItem('pharma_pos_v2');
  if (saved) {
    const d = JSON.parse(saved);
    products = d.products || [];
    sales = d.sales || [];
    // Merge but keep new defaults for name/address/currency if still old values
    const s = d.settings || {};
