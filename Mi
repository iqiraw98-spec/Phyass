    { id: 12, name: 'شامبو كيتوكونازول 2%', scientific: 'Ketoconazole', barcode: '6291001234572', category: 'جلدية', price: 32.00, cost: 16.00, stock: 18, unit: 'زجاجة', expiry: '2027-05', manufacturer: 'جانسن', icon: '🧴' },
  ];
