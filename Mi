}

function saveData() {
  localStorage.setItem('pharma_pos_v2', JSON.stringify({ products, sales, settings }));
}

// ============================================================
// NAVIGATION
// ============================================================
function showPage(name, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => {
    if (b.getAttribute('onclick') && b.getAttribute('onclick').includes("'" + name + "'")) b.classList.add('active');
  });
  if (name === 'inventory') renderInventory();
  if (name === 'reports') renderReports();
  if (name === 'settings') loadSettings();
}

// ============================================================
// CLOCK
// ============================================================
function updateClock() {
  const now = new Date();
  document.getElementById('clock').textContent = now.toLocaleTimeString('ar');
  document.getElementById('dateDisplay').textContent = now.toLocaleDateString('ar-SA', { weekday: 'long', day: 'numeric', month: 'long' });
}
setInterval(updateClock, 1000);
updateClock();

// ============================================================
// PRODUCTS GRID (Cashier)
// ============================================================
let activeCategory = '';
function getCategories() {
  return [...new Set(products.map(p => p.category))];
}

function renderCategoryFilters() {
  const cats = getCategories();
  const c = document.getElementById('catFilters');
  c.innerHTML = `<button class="cat-btn active" onclick="setCategory('', this)">الكل</button>`;
  cats.forEach(cat => {
    c.innerHTML += `<button class="cat-btn" onclick="setCategory('${cat}', this)">${cat}</button>`;
  });
}

function setCategory(cat, btn) {
  activeCategory = cat;
  document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderProductsGrid();
}

function filterProducts() {
  renderProductsGrid();
}

function renderProductsGrid() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  const grid = document.getElementById('productsGrid');
  let filtered = products.filter(p => {
    const matchCat = !activeCategory || p.category === activeCategory;
    const matchQ = !q || p.name.toLowerCase().includes(q) || p.barcode.includes(q) || (p.scientific || '').toLowerCase().includes(q);
    return matchCat && matchQ;
  });

  if (filtered.length === 0) {
    grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;color:var(--text2);padding:40px;">لا توجد منتجات مطابقة</div>`;
    return;
  }

  grid.innerHTML = filtered.map(p => {
    const isOut = p.stock <= 0;
    const isLow = !isOut && p.stock <= settings.lowStockThreshold;
    return `
    <div class="product-card ${isOut ? 'out-of-stock' : ''} ${isLow ? 'low-stock' : ''}" onclick="addToCart(${p.id})">
      <div class="p-icon">${p.icon || '💊'}</div>
      <div class="p-name">${p.name}</div>
      <div class="p-barcode">${p.barcode}</div>
      <div class="p-price">${p.price.toFixed(2)} ${settings.currency}</div>
      <div class="p-stock">${isOut ? '❌ نفذت الكمية' : (isLow ? '⚠️ ' : '') + p.stock + ' ' + (p.unit || '')}</div>
    </div>`;
  }).join('');
}

// ============================================================
// BARCODE
// ============================================================
function handleBarcodeKey(e) {
  if (e.key === 'Enter') {
    const q = document.getElementById('searchInput').value.trim();
    const p = products.find(x => x.barcode === q);
    if (p) {
      addToCart(p.id);
      document.getElementById('searchInput').value = '';
      renderProductsGrid();
    }
  }
}

function simulateBarcode() {
  const p = products.filter(x => x.stock > 0);
  if (!p.length) return;
  const rnd = p[Math.floor(Math.random() * p.length)];
  document.getElementById('searchInput').value = rnd.barcode;
  setTimeout(() => {
    addToCart(rnd.id);
    document.getElementById('searchInput').value = '';
    renderProductsGrid();
    showToast('📷 تم مسح: ' + rnd.name, 'success');
  }, 300);
}

// ============================================================
// CART
// ============================================================
function addToCart(id) {
  const p = products.find(x => x.id === id);
  if (!p || p.stock <= 0) { showToast('❌ المنتج غير متوفر', 'error'); return; }
  const existing = cart.find(c => c.id === id);
  if (existing) {
    if (existing.qty >= p.stock) { showToast('⚠️ لا يوجد مخزون كافٍ', 'error'); return; }
    existing.qty++;
  } else {
    cart.push({ id, qty: 1, name: p.name, price: p.price });
  }
  renderCart();
  showToast('✅ تمت الإضافة: ' + p.name, 'success');
}

function removeFromCart(id) {
  cart = cart.filter(c => c.id !== id);
  renderCart();
}

function changeQty(id, delta) {
  const item = cart.find(c => c.id === id);
  const p = products.find(x => x.id === id);
  if (!item) return;
  item.qty += delta;
  if (item.qty <= 0) { removeFromCart(id); return; }
  if (item.qty > p.stock) { item.qty = p.stock; showToast('⚠️ الكمية المتاحة: ' + p.stock, 'error'); }
  renderCart();
}

function clearCart() {
  cart = [];
  renderCart();
  document.getElementById('discountInput').value = '';
  document.getElementById('discountAmount').value = '';
}

function renderCart() {
  const el = document.getElementById('cartItems');
  document.getElementById('cartCount').textContent = cart.reduce((s, i) => s + i.qty, 0);
  if (cart.length === 0) {
    el.innerHTML = `<div class="cart-empty"><div class="cart-empty-icon">🛒</div><div>اختر منتجاً للبدء</div></div>`;
    updateTotals();
    return;
  }
  el.innerHTML = cart.map(item => `
    <div class="cart-item">
      <div class="ci-name">${item.name}</div>
      <div class="ci-qty">
        <button class="qty-btn" onclick="changeQty(${item.id}, -1)">−</button>
        <span class="qty-val">${item.qty}</span>
        <button class="qty-btn" onclick="changeQty(${item.id}, 1)">+</button>
      </div>
      <div class="ci-price">${(item.price * item.qty).toFixed(2)}</div>
      <button class="ci-del" onclick="removeFromCart(${item.id})">🗑</button>
    </div>`).join('');
  updateTotals();
}

function updateTotals() {
  const subtotal = cart.reduce((s, i) => s + i.price * i.qty, 0);
  const discPct = parseFloat(document.getElementById('discountInput').value) || 0;
  const discAmt = parseFloat(document.getElementById('discountAmount').value) || 0;
  const discount = Math.min(subtotal, subtotal * (discPct / 100) + discAmt);
  const total = subtotal - discount;
  document.getElementById('subtotalDisplay').textContent = subtotal.toFixed(2) + ' ' + settings.currency;
  document.getElementById('discountDisplay').textContent = discount.toFixed(2) + ' ' + settings.currency;
  document.getElementById('totalDisplay').textContent = total.toFixed(2) + ' ' + settings.currency;
}

function getTotal() {
  const subtotal = cart.reduce((s, i) => s + i.price * i.qty, 0);
  const discPct = parseFloat(document.getElementById('discountInput').value) || 0;
  const discAmt = parseFloat(document.getElementById('discountAmount').value) || 0;
  const discount = Math.min(subtotal, subtotal * (discPct / 100) + discAmt);
  return subtotal - discount;
}

function holdInvoice() {
  showToast('⏸ تم تعليق الفاتورة', 'success');
}

// ============================================================
// PAYMENT
// ============================================================
function openPayment(method) {
  if (cart.length === 0) { showToast('🛒 السلة فارغة!', 'error'); return; }
  currentPaymentMethod = method;
  const total = getTotal();
  document.getElementById('paymentTitle').textContent = method === 'cash' ? '💵 الدفع النقدي' : '💳 الدفع بالبطاقة';
  document.getElementById('payDue').textContent = total.toFixed(2) + ' ' + settings.currency;
  document.getElementById('payReceived').value = '';
  document.getElementById('changeDisplay').style.display = 'none';
  buildNumpad();
  if (method === 'card') {
    document.getElementById('payReceived').value = total.toFixed(2);
    calcChange();
  }
  document.getElementById('paymentModal').classList.add('open');
}

function buildNumpad() {
  const np = document.getElementById('numpad');
  const keys = ['1','2','3','4','5','6','7','8','9','','0','.'];
  np.innerHTML = keys.map((k, i) => {
    if (k === '') return `<button class="num-btn clear" onclick="clearPay()">⌫</button>`;
    const cls = k === '0' ? '' : '';
    return `<button class="num-btn ${cls}" onclick="appendNum('${k}')">${k}</button>`;
  }).join('');
}

function appendNum(n) {
  const inp = document.getElementById('payReceived');
  if (n === '.' && inp.value.includes('.')) return;
  inp.value += n;
  calcChange();
}

function clearPay() {
  const inp = document.getElementById('payReceived');
  inp.value = inp.value.slice(0, -1);
  calcChange();
}

function calcChange() {
  const received = parseFloat(document.getElementById('payReceived').value) || 0;
  const due = getTotal();
  const change = received - due;
  const cd = document.getElementById('changeDisplay');
  if (received > 0) {
    cd.style.display = 'block';
    document.getElementById('changeAmount').textContent = (change >= 0 ? change : 0).toFixed(2) + ' ' + settings.currency;
    cd.style.borderColor = change >= 0 ? 'var(--success)' : 'var(--danger)';
    document.getElementById('changeAmount').style.color = change >= 0 ? 'var(--success)' : 'var(--danger)';
  } else {
    cd.style.display = 'none';
  }
}

function completeSale() {
  const received = parseFloat(document.getElementById('payReceived').value) || 0;
  const total = getTotal();
  if (currentPaymentMethod === 'cash' && received < total) {
    showToast('⚠️ المبلغ المدفوع غير كافٍ', 'error');
    return;
  }
  // Deduct stock
  cart.forEach(item => {
    const p = products.find(x => x.id === item.id);
    if (p) p.stock -= item.qty;
  });
  // Save sale
  const sale = {
    id: Date.now(),
    date: new Date().toISOString(),
    items: [...cart],
    subtotal: cart.reduce((s, i) => s + i.price * i.qty, 0),
    discount: cart.reduce((s, i) => s + i.price * i.qty, 0) - total,
    total,
    method: currentPaymentMethod,
    received: currentPaymentMethod === 'cash' ? received : total,
    change: currentPaymentMethod === 'cash' ? received - total : 0
  };
  sales.push(sale);
  saveData();
  closeModal('paymentModal');
  showReceipt(sale);
  clearCart();
  renderProductsGrid();
}

function showReceipt(sale) {
  const r = document.getElementById('receiptContent');
  const date = new Date(sale.id).toLocaleString('ar');
  r.innerHTML = `
    <div class="receipt-header">
      <strong style="font-size:1.1em;">${settings.pharmName}</strong><br>
      ${settings.pharmAddress}<br>
      هاتف: ${settings.pharmPhone}<br>
      ترخيص: ${settings.pharmLicense}
    </div>
    <hr>
    <div class="receipt-row"><span>رقم الفاتورة:</span><span>#${sale.id.toString().slice(-6)}</span></div>
    <div class="receipt-row"><span>التاريخ:</span><span>${date}</span></div>
    <div class="receipt-row"><span>طريقة الدفع:</span><span>${sale.method === 'cash' ? 'نقدي' : 'بطاقة'}</span></div>
    <hr>
    ${sale.items.map(i => `
    <div class="receipt-row"><span>${i.name}</span><span></span></div>
    <div class="receipt-row" style="color:#8899bb;font-size:0.75em;"><span>${i.qty} × ${i.price.toFixed(2)}</span><span>${(i.qty * i.price).toFixed(2)} ${settings.currency}</span></div>
    `).join('')}
    <hr>
    <div class="receipt-row"><span>المجموع:</span><span>${sale.subtotal.toFixed(2)} ${settings.currency}</span></div>
    ${sale.discount > 0 ? `<div class="receipt-row"><span>الخصم:</span><span>-${sale.discount.toFixed(2)} ${settings.currency}</span></div>` : ''}
    <div class="receipt-row" style="font-weight:700;font-size:1.1em;"><span>الإجمالي:</span><span>${sale.total.toFixed(2)} ${settings.currency}</span></div>
    ${sale.method === 'cash' ? `
    <div class="receipt-row"><span>المدفوع:</span><span>${sale.received.toFixed(2)} ${settings.currency}</span></div>
    <div class="receipt-row"><span>الباقي:</span><span>${sale.change.toFixed(2)} ${settings.currency}</span></div>` : ''}
    <hr>
    <div style="text-align:center;color:#8899bb;font-size:0.75em;">شكراً لزيارتكم<br>نتمنى لكم الصحة والعافية</div>
  `;
  document.getElementById('receiptModal').classList.add('open');
}

// ============================================================
// INVENTORY
// ============================================================
function renderInventory() {
  const q = (document.getElementById('invSearch').value || '').toLowerCase();
  const cat = document.getElementById('invCatFilter').value;
  const cats = getCategories();
  const cf = document.getElementById('invCatFilter');
  const currentVal = cf.value;
  cf.innerHTML = '<option value="">كل الفئات</option>' + cats.map(c => `<option ${c === currentVal ? 'selected' : ''} value="${c}">${c}</option>`).join('');
  cf.value = currentVal;

  let filtered = products.filter(p => {
    const matchQ = !q || p.name.toLowerCase().includes(q) || p.barcode.includes(q) || (p.scientific || '').toLowerCase().includes(q);
    const matchCat = !cat || p.category === cat;
    return matchQ && matchCat;
  });

  const tbody = document.getElementById('invBody');
  tbody.innerHTML = filtered.map(p => {
    const status = p.stock <= 0 ? '<span class="badge badge-out">نفذت</span>' :
      p.stock <= settings.lowStockThreshold ? '<span class="badge badge-low">منخفض</span>' :
      '<span class="badge badge-ok">متوفر</span>';

    const expiry = p.expiry ? checkExpiry(p.expiry) : '<span class="expiry-badge expiry-ok">—</span>';

    return `<tr>
      <td><span style="font-family:'IBM Plex Mono',monospace;font-size:0.75rem;">${p.barcode}</span></td>
      <td><strong>${p.name}</strong><br><span style="font-size:0.72rem;color:var(--text2);">${p.scientific || ''}</span></td>
      <td>${p.category}</td>
      <td><strong>${p.price.toFixed(2)} ${settings.currency}</strong><br><span style="font-size:0.72rem;color:var(--text2);">تكلفة: ${(p.cost || 0).toFixed(2)}</span></td>
      <td><strong>${p.stock}</strong> ${p.unit || ''}</td>
      <td>${expiry}</td>
      <td>${status}</td>
      <td>
        <div class="action-btns">
          <button class="act-btn" onclick="openEditProduct(${p.id})">✏️ تعديل</button>
          <button class="act-btn" onclick="addStock(${p.id})">➕ إضافة</button>
          <button class="act-btn danger" onclick="deleteProduct(${p.id})">🗑</button>
        </div>
      </td>
    </tr>`;
  }).join('');
}

function checkExpiry(expiry) {
  const now = new Date();
  const exp = new Date(expiry + '-01');
  const diff = (exp - now) / (1000 * 60 * 60 * 24);
  if (diff < 0) return `<span class="expiry-badge expiry-exp">منتهي ❌ (${expiry})</span>`;
  if (diff <= settings.expiryWarnDays) return `<span class="expiry-badge expiry-soon">⚠️ ${expiry}</span>`;
  return `<span class="expiry-badge expiry-ok">${expiry}</span>`;
}

function openAddProduct() {
  editingProductId = null;
  document.getElementById('productModalTitle').textContent = '➕ إضافة منتج جديد';
  ['pName','pScientific','pBarcode','pPrice','pCost','pStock','pExpiry','pManufacturer'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('pIcon').value = '💊';
  document.getElementById('pCategory').value = 'مسكنات الألم';
  document.getElementById('pUnit').value = 'علبة';
  document.getElementById('productModal').classList.add('open');
}

function openEditProduct(id) {
  editingProductId = id;
  const p = products.find(x => x.id === id);
  document.getElementById('productModalTitle').textContent = '✏️ تعديل المنتج';
  document.getElementById('pName').value = p.name;
  document.getElementById('pScientific').value = p.scientific || '';
  document.getElementById('pBarcode').value = p.barcode;
  document.getElementById('pCategory').value = p.category;
  document.getElementById('pPrice').value = p.price;
  document.getElementById('pCost').value = p.cost || '';
  document.getElementById('pStock').value = p.stock;
  document.getElementById('pUnit').value = p.unit || 'علبة';
  document.getElementById('pExpiry').value = p.expiry || '';
  document.getElementById('pManufacturer').value = p.manufacturer || '';
  document.getElementById('pIcon').value = p.icon || '💊';
  document.getElementById('productModal').classList.add('open');
}

function saveProduct() {
  const name = document.getElementById('pName').value.trim();
  const barcode = document.getElementById('pBarcode').value.trim();
  const price = parseFloat(document.getElementById('pPrice').value);
  const stock = parseInt(document.getElementById('pStock').value);
  if (!name || !barcode || isNaN(price) || isNaN(stock)) {
    showToast('⚠️ يرجى ملء جميع الحقول المطلوبة', 'error'); return;
  }
  const data = {
    name, barcode,
    scientific: document.getElementById('pScientific').value.trim(),
    category: document.getElementById('pCategory').value,
    price, cost: parseFloat(document.getElementById('pCost').value) || 0,
    stock,
    unit: document.getElementById('pUnit').value,
    expiry: document.getElementById('pExpiry').value,
    manufacturer: document.getElementById('pManufacturer').value.trim(),
    icon: document.getElementById('pIcon').value.trim() || '💊'
  };
  if (editingProductId) {
    const idx = products.findIndex(x => x.id === editingProductId);
    products[idx] = { ...products[idx], ...data };
    showToast('✅ تم تحديث المنتج', 'success');
  } else {
    data.id = Date.now();
    products.push(data);
    showToast('✅ تمت إضافة المنتج', 'success');
  }
  saveData();
  closeModal('productModal');
  renderInventory();
  renderProductsGrid();
  renderCategoryFilters();
}

function addStock(id) {
  const p = products.find(x => x.id === id);
  const qty = parseInt(prompt(`إضافة كمية لـ "${p.name}" (الكمية الحالية: ${p.stock})`));
  if (!qty || qty < 1) return;
  p.stock += qty;
  saveData();
  renderInventory();
  renderProductsGrid();
  showToast(`✅ تمت إضافة ${qty} وحدة لـ ${p.name}`, 'success');
}

function deleteProduct(id) {
  if (!confirm('هل تريد حذف هذا المنتج؟')) return;
  products = products.filter(x => x.id !== id);
  saveData();
  renderInventory();
  renderProductsGrid();
  renderCategoryFilters();
  showToast('🗑 تم حذف المنتج', 'success');
}

function exportCSV() {
  const rows = [['الباركود','الاسم','الفئة','السعر','الكمية','انتهاء الصلاحية']];
  products.forEach(p => rows.push([p.barcode, p.name, p.category, p.price, p.stock, p.expiry || '']));
  const csv = rows.map(r => r.join(',')).join('\n');
  const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'pharmacy_inventory.csv';
  a.click();
  showToast('📤 تم تصدير المخزون', 'success');
}

// ============================================================
// REPORTS
// ============================================================
function renderReports() {
  const todaySales = sales.filter(s => new Date(s.date).toDateString() === new Date().toDateString());
  const todayRevenue = todaySales.reduce((s, x) => s + x.total, 0);
  const totalRevenue = sales.reduce((s, x) => s + x.total, 0);
  const lowStock = products.filter(p => p.stock > 0 && p.stock <= settings.lowStockThreshold).length;
  const outOfStock = products.filter(p => p.stock <= 0).length;

  document.getElementById('statsGrid').innerHTML = `
    <div class="stat-card green"><div class="stat-icon">💰</div><div class="stat-val">${todayRevenue.toFixed(0)}</div><div class="stat-label">إيرادات اليوم (${settings.currency})</div></div>
    <div class="stat-card blue"><div class="stat-icon">🧾</div><div class="stat-val">${todaySales.length}</div><div class="stat-label">مبيعات اليوم</div></div>
    <div class="stat-card teal"><div class="stat-icon">💊</div><div class="stat-val">${products.length}</div><div class="stat-label">إجمالي المنتجات</div></div>
    <div class="stat-card orange"><div class="stat-icon">⚠️</div><div class="stat-val">${lowStock + outOfStock}</div><div class="stat-label">تنبيهات المخزون</div></div>
  `;

  // Top products
  const soldMap = {};
  sales.forEach(s => s.items.forEach(i => {
    soldMap[i.name] = (soldMap[i.name] || 0) + i.qty;
  }));
  const top = Object.entries(soldMap).sort((a, b) => b[1] - a[1]).slice(0, 6);
  const maxSold = top[0]?.[1] || 1;
  document.getElementById('topProducts').innerHTML = top.length ? top.map(([name, qty]) => `
    <div class="sale-bar-wrap">
      <div class="sale-bar-label"><span>${name}</span><span>${qty} وحدة</span></div>
      <div class="sale-bar"><div class="sale-bar-fill" style="width:${(qty / maxSold * 100)}%"></div></div>
    </div>`).join('') : '<div style="color:var(--text2);font-size:0.85rem;">لا توجد مبيعات بعد</div>';

  // Stock alerts
  const alerts = products.filter(p => p.stock <= settings.lowStockThreshold);
  document.getElementById('stockAlerts').innerHTML = alerts.length ? alerts.slice(0, 8).map(p => `
    <div class="sale-row">
      <span>${p.name}</span>
      <span class="badge ${p.stock <= 0 ? 'badge-out' : 'badge-low'}">${p.stock <= 0 ? 'نفذت' : p.stock + ' متبقٍ'}</span>
    </div>`).join('') : '<div style="color:var(--success);font-size:0.85rem;">✅ جميع المنتجات متوفرة</div>';

  // Recent sales
  const recent = [...sales].reverse().slice(0, 8);
  document.getElementById('recentSales').innerHTML = recent.length ? recent.map(s => `
    <div class="sale-row">
      <span style="font-size:0.78rem;">${new Date(s.date).toLocaleString('ar')}</span>
      <span style="color:var(--success);font-weight:700;">${s.total.toFixed(2)} ${settings.currency}</span>
    </div>`).join('') : '<div style="color:var(--text2);font-size:0.85rem;">لا توجد مبيعات</div>';

  // Expiry
  const expiring = products.filter(p => {
    if (!p.expiry) return false;
    const exp = new Date(p.expiry + '-01');
    const diff = (exp - new Date()) / (1000 * 60 * 60 * 24);
    return diff <= 90;
  }).sort((a, b) => new Date(a.expiry) - new Date(b.expiry));
  document.getElementById('expiryReport').innerHTML = expiring.length ? expiring.slice(0, 8).map(p => `
    <div class="sale-row">
      <span>${p.name}</span>
      ${checkExpiry(p.expiry)}
    </div>`).join('') : '<div style="color:var(--success);font-size:0.85rem;">✅ لا توجد منتجات قريبة الانتهاء</div>';
}

// ============================================================
// SETTINGS
// ============================================================
function loadSettings() {
  document.getElementById('pharmName').value = settings.pharmName;
  document.getElementById('pharmLicense').value = settings.pharmLicense;
  document.getElementById('pharmAddress').value = settings.pharmAddress;
  document.getElementById('pharmPhone').value = settings.pharmPhone;
  document.getElementById('currency').value = settings.currency;
  document.getElementById('taxRate').value = settings.taxRate;
  document.getElementById('lowStockThreshold').value = settings.lowStockThreshold;
  document.getElementById('expiryWarnDays').value = settings.expiryWarnDays;
}

function saveSettings() {
  settings.pharmName = document.getElementById('pharmName').value;
  settings.pharmLicense = document.getElementById('pharmLicense').value;
  settings.pharmAddress = document.getElementById('pharmAddress').value;
  settings.pharmPhone = document.getElementById('pharmPhone').value;
  settings.currency = document.getElementById('currency').value;
  settings.taxRate = parseFloat(document.getElementById('taxRate').value) || 0;
  settings.lowStockThreshold = parseInt(document.getElementById('lowStockThreshold').value) || 10;
  settings.expiryWarnDays = parseInt(document.getElementById('expiryWarnDays').value) || 30;
  saveData();
}

function resetData() {
  if (!confirm('هل تريد إعادة ضبط البيانات التجريبية؟')) return;
  localStorage.removeItem('pharma_pos_v2');
  initData();
  showToast('🔄 تمت إعادة الضبط', 'success');
  renderProductsGrid();
  renderCategoryFilters();
}

function exportAll() {
  const data = JSON.stringify({ products, sales, settings }, null, 2);
  const blob = new Blob([data], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'pharmacy_backup_' + new Date().toISOString().slice(0,10) + '.json';
  a.click();
  showToast('💾 تم تصدير البيانات', 'success');
}

// ============================================================
// MODALS & TOAST
// ============================================================
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
}
document.querySelectorAll('.modal-overlay').forEach(m => {
  m.addEventListener('click', e => { if (e.target === m) m.classList.remove('open'); });
});

function showToast(msg, type = '') {
  const c = document.getElementById('toastContainer');
  const t = document.createElement('div');
  t.className = 'toast ' + type;
  t.textContent = msg;
  c.appendChild(t);
  setTimeout(() => t.remove(), 2500);
}

// ============================================================
// INIT
// ============================================================
initData();
renderCategoryFilters();
renderProductsGrid();
</script>
